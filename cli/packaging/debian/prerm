#!/bin/sh
set -e

case "$1" in
    remove|purge)
        if command -v systemctl >/dev/null 2>&1; then
            systemctl stop openme.service 2>/dev/null || true
            systemctl disable openme.service 2>/dev/null || true
            systemctl daemon-reload || true
        fi
        ;;
esac

case "$1" in
    purge)
        # Remove the dedicated service account created during installation.
        if getent passwd openme >/dev/null; then
            deluser --system openme || true
        fi
        if getent group openme >/dev/null; then
            delgroup --only-if-empty openme 2>/dev/null || true
        fi
        ;;
esac

exit 0
