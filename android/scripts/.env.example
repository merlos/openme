# android/scripts/.env.example
#
# Copy this file to android/scripts/.env and fill in your values.
# .env is in .gitignore — never commit it.
#
# Used by: android/scripts/release-android.sh

# ── Java (required on macOS if `java` is not on PATH) ─────────────────────────
# Android Studio ships its own JDK.  Point JAVA_HOME at it so Gradle can find it.
# On macOS the path is usually one of:
#   /Applications/Android Studio.app/Contents/jbr/Contents/Home   (recent)
#   /Applications/Android Studio.app/Contents/jre/Contents/Home   (older)
JAVA_HOME=/Applications/Android\ Studio.app/Contents/jbr/Contents/Home

# ── Required for signed release APK ──────────────────────────────────────────

# Absolute path to your .jks / .keystore file.
ANDROID_KEYSTORE_FILE=/path/to/release.keystore

# Password for the keystore file.
ANDROID_KEYSTORE_PASSWORD=your-keystore-password

# Alias of the signing key inside the keystore.
ANDROID_KEY_ALIAS=openme

# Password for the signing key (may be the same as ANDROID_KEYSTORE_PASSWORD).
ANDROID_KEY_PASSWORD=your-key-password
