# apple/scripts/.env.example
#
# Copy this file to apple/scripts/.env and fill in your values.
# .env is in .gitignore — never commit it.
#
# Used by: apple/scripts/release-macos.sh

# ── Required ──────────────────────────────────────────────────────────────────

# Your 10-character Apple Team ID.
# Find it at: https://developer.apple.com → Account → Membership
APPLE_TEAM_ID=XXXXXXXXXX

# App Store Connect API key ID (short alphanumeric, e.g. ABCD1234EF).
# Find it at: https://appstoreconnect.apple.com → Users and Access → Integrations
APPLE_API_KEY_ID=XXXXXXXXXX

# Issuer UUID from the same App Store Connect page.
APPLE_API_KEY_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Absolute path to the .p8 API key file downloaded from App Store Connect.
# The file can only be downloaded once — store it somewhere safe.
APPLE_API_KEY_PATH=/path/to/AuthKey_XXXXXXXXXX.p8

# ── Optional ──────────────────────────────────────────────────────────────────

# codesign identity. Default is "Developer ID Application" which works when
# exactly one Developer ID Application cert is in your keychain.
# Use the full form to disambiguate if you have multiple certs:
#   DEVELOPER_ID_IDENTITY=Developer ID Application: Your Name (TEAMID)
# DEVELOPER_ID_IDENTITY=Developer ID Application
